# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Gemini LLM (using OpenAI-compatible proxy)
GEMINI_API_KEY="your-api-key"
GEMINI_BASE_URL="https://hiapi.online/v1"
GEMINI_MODEL="gemini-3-pro"
GEMINI_FLASH_MODEL="gemini-2.5-flash"
GEMINI_FLASH_LITE_MODEL="gemini-2.5-flash-lite"
BACKGROUND_LLM_MODEL="gemini-2.5-flash-lite"
TOPIC_GENERATION_MODEL="gemini-2.5-flash"
EVALUATION_MODEL="gemini-2.5-flash"

# Google official Gemini (recommended for critical low-latency paths)
GEMINI_OFFICIAL_API_KEY="your-google-ai-studio-api-key"
GEMINI_OFFICIAL_MODEL="gemini-2.5-flash"

# Gemini Live (bidi real-time audio)
NEXT_PUBLIC_ENABLE_GEMINI_LIVE="false"
GEMINI_LIVE_MODEL="gemini-2.5-flash-native-audio-preview-12-2025"
# Optional: override these if Gemini Live must go through a relay or special egress
# GEMINI_LIVE_API_BASE_URL="https://generativelanguage.googleapis.com"
# GEMINI_LIVE_WS_URL="wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1alpha.GenerativeService.BidiGenerateContentConstrained"
# GEMINI_LIVE_PROXY_URL="http://127.0.0.1:7897"

# Gemini TTS (official Google Gemini API, for coach review audio)
GEMINI_TTS_API_KEY="your-google-ai-studio-api-key"
GEMINI_TTS_MODEL="gemini-2.5-flash-preview-tts"
COACH_REVIEW_TTS_PROVIDER="gemini"

# Azure Speech Services (for TTS and STT)
AZURE_SPEECH_KEY="your-azure-speech-key"
AZURE_SPEECH_REGION="westus3"

# ElevenLabs (for feedback/review TTS)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# NextAuth.js (generate with: openssl rand -base64 32)
AUTH_SECRET="your-auth-secret"

# Google OAuth (optional: enables Google login)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# WeChat Official Account (optional: enables WeChat login)
AUTH_WECHAT_APP_ID=
AUTH_WECHAT_APP_SECRET=

# Vercel Blob (optional, for audio storage)
# BLOB_READ_WRITE_TOKEN="your-blob-token"

# Invite-only beta gate (recommended for initial production launch)
INVITE_GATE_ENABLED="false"
INVITE_GATE_TOKENS="friend-a-2026,friend-b-2026"
INVITE_GATE_COOKIE_NAME="speakonimage_invite"
INVITE_GATE_ACCESS_PATH="/beta/access"

# Public app URL (used for metadata and deployment)
APP_CANONICAL_URL="https://www.dopling.ai"
